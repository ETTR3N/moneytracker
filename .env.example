# PostgreSQL connection string (e.g. from Neon, Supabase, or Railway).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# The password required to unlock the app. Choose your own.
APP_PASSWORD="change-me"

# Random secret used to sign the login session cookie.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-me-too"

# Free Gemini API key for the money Assistant chat, from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="change-me-as-well"

# Optional: override the Gemini model used by the assistant (defaults to gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"
